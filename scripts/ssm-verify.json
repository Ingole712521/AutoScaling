{
  "commands": [
    "echo ===BOOTSTRAP_MARKER===",
    "test -f /var/log/emqx-bootstrap.ok && echo BOOTSTRAP_OK || echo BOOTSTRAP_PENDING",
    "echo ===BOOTSTRAP_LOG===",
    "tail -n 8 /var/log/emqx-bootstrap.log 2>/dev/null || echo NO_BOOTSTRAP_LOG",
    "echo ===EMQX_STATUS===",
    "/usr/bin/emqx ctl status 2>&1 | head -n 3",
    "echo ===CLUSTER_STATUS===",
    "/usr/bin/emqx ctl cluster status 2>&1 | head -n 5",
    "echo ===PORTS===",
    "ss -tln | grep -E ':1883|:18083' || echo PORTS_NOT_OPEN"
  ]
}
