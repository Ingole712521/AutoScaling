# Copy to terraform.tfvars and set required secrets before apply.
aws_region              = "ap-south-1"
project_name            = "emqx-prod"
emqx_version            = "5.8.9"
# Performance tuning (https://docs.emqx.com/en/emqx/latest/performance/tune.html)
emqx_tune_nofile              = 2097152
emqx_tune_max_ports           = 2097152
emqx_tune_acceptors           = 64
emqx_tune_max_connections     = 1024000
emqx_tune_dist_buffer_size_kb = 2097151
use_secrets_manager     = true
# secrets_manager_secret_name = "emqx-prod/emqx"  # optional; default is {project_name}/emqx
enable_grafana          = true
grafana_admin_username  = "admin"
grafana_admin_password  = "ChangeMe!GrafanaPassword"
# grafana_allowed_cidr  = "0.0.0.0/0"  # empty = same as dashboard_allowed_cidr
emqx_node_cookie        = "ChangeThisCookieForProduction"
emqx_dashboard_username = "admin"
emqx_dashboard_password = "ChangeMe!StrongPassword"
emqx_mqtt_enable_authn  = true
emqx_mqtt_username      = "mqtt_user"
emqx_mqtt_password      = "ChangeMe!MqttPassword"
emqx_cluster_autoclean  = "2m"
asg_health_check_grace_period = 300
asg_instance_warmup_sec       = 300
dashboard_allowed_cidr  = "0.0.0.0/0"   # Restrict to your office/VPN CIDR in production
ssh_allowed_cidr        = "0.0.0.0/0"   # Restrict to your office/VPN CIDR in production

# MQTT over TLS (optional) — NLB :8883 terminates TLS using ACM; backends stay on :1883
# enable_mqtt_tls       = true
# acm_certificate_arn   = "arn:aws:acm:ap-south-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
core_instance_type      = "t3.small"
core_min_size           = 1
core_desired_capacity   = 1
core_max_size           = 2
core_scale_out_cpu_threshold = 20
core_scale_in_cpu_threshold  = 5
replicant_instance_type = "t3.small"
replicant_min_size      = 1
replicant_desired_capacity = 1
replicant_max_size      = 4
scale_out_network_target_bytes = 5000
scale_out_cpu_threshold        = 25
scale_out_network_evaluation_periods = 2
scale_in_cpu_threshold         = 5
autoscaling_cooldown_sec       = 60
scale_in_cooldown_sec          = 0
scale_in_metric_period_sec     = 30
scale_in_evaluation_periods    = 2
